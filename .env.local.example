# Sheety API endpoint for RSVP submissions
# Steps:
# 1. Create a Google Sheet named "Georgia And Jordan" with a tab called "rsvps"
#    Columns: name | attending | guests | dietary | message | submittedAt
# 2. Go to https://sheety.co, connect your sheet, enable POST requests
# 3. Paste your endpoint URL below
# 4. Copy this file to .env.local and fill in your URL

SHEETY_API_URL=https://api.sheety.co/YOUR_USER_ID/georgiaAndJordan/rsvps
